{
  "name": "@bitsnbobs/starch",
  "version": "0.0.0",
  "type": "module",
  "description": "Animated diagram library for documenting application internals",
  "main": "./dist/starch.js",
  "module": "./dist/starch.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/starch.js",
      "types": "./dist/index.d.ts"
    },
    "./embed": "./dist/starch-embed.iife.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite --config vite.app.config.ts",
    "build": "vite build",
    "build:embed": "vite build --config vite.embed.config.ts",
    "build:app": "vite build --config vite.app.config.ts",
    "build:all": "npm run build && npm run build:embed && npm run build:app",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "@prosemirror-adapter/react": "^0.5.3",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "zod": "^4.3.6"
  }
}

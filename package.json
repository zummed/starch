{
  "name": "@bitsnbobs/starch",
  "version": "0.0.0",
  "type": "module",
  "description": "Animated diagram library for documenting application internals",
  "main": "./dist/starch.js",
  "module": "./dist/starch.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/starch.js",
      "types": "./dist/index.d.ts"
    },
    "./embed": "./dist/starch-embed.iife.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:embed": "vite build --config vite.embed.config.ts",
    "build:app": "vite build --config vite.app.config.ts",
    "build:all": "npm run build && npm run build:embed && npm run build:app",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "semantic-release": "^25.0.3",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@codemirror/lint": "^6.9.5",
    "json5": "^2.2.3",
    "prismjs": "^1.30.0",
    "zod": "^4.3.6"
  }
}
